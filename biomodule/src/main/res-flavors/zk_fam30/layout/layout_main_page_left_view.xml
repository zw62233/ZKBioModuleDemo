<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/amt_bg_color"
        android:orientation="vertical">


        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_margin="16dp"
            android:adjustViewBounds="true"
            android:src="@drawable/logo_fill_white"
            app:layout_constraintBottom_toTopOf="@id/guideline5"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <TextView
            android:id="@+id/tv_welcome_tips"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:gravity="center"
            android:scrollbarFadeDuration="1000"
            android:scrollbarStyle="outsideOverlay"
            android:scrollbars="vertical"
            android:text="@string/multimodel_biometrics_ndemo_nfor_face_and_palm"
            android:textColor="@color/amt_text_color"
            android:textSize="@dimen/text_size_30sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/control_pane_layout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/iv_logo" />


        <androidx.appcompat.widget.LinearLayoutCompat
            android:id="@+id/control_pane_layout"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/btn_about"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?android:attr/selectableItemBackground"
                android:drawableTop="@drawable/ic_about"
                android:gravity="center"
                android:text="@string/about"
                android:textColor="@color/amt_text_color"
                android:textSize="@dimen/text_size_16sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btn_user_manage"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?android:attr/selectableItemBackground"
                android:drawableTop="@drawable/ic_user_manage"
                android:gravity="center"
                android:text="@string/tool_panel_users"
                android:textColor="@color/amt_text_color"
                android:textSize="@dimen/text_size_14sp" />

            <TextView
                android:id="@+id/btn_module_user_manage"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?android:attr/selectableItemBackground"
                android:drawableTop="@drawable/ic_user_manage"
                android:gravity="center"
                android:text="@string/tool_panel_module_users"
                android:textColor="@color/amt_text_color"
                android:textSize="@dimen/text_size_14sp" />


            <TextView
                android:id="@+id/btn_health"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?android:attr/selectableItemBackground"
                android:drawableTop="@drawable/ic_medical"
                android:gravity="center"
                android:text="@string/health_biometrics"
                android:textColor="@color/amt_text_color"
                android:textSize="@dimen/nav_bar_btn_text_size"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btn_setting_menu"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?android:attr/selectableItemBackground"
                android:drawableTop="@drawable/ic_settings"
                android:gravity="center"
                android:text="@string/settings"
                android:textColor="@color/amt_text_color"
                android:textSize="@dimen/text_size_14sp" />
        </androidx.appcompat.widget.LinearLayoutCompat>

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.3" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:MyToolBar="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">


        <com.armatura.biomodule.view.ToolBar
            android:id="@+id/my_tool_bar"
            style="@style/tool_bar_with_back_style"
            MyToolBar:left_button_visible="true"
            MyToolBar:right_button_visible="false" />


        <ImageView
            android:id="@+id/pick_image_iv"
            android:layout_width="200dp"
            android:layout_height="355.52dp"
            android:layout_centerInParent="true" />


        <LinearLayout
            android:id="@+id/btn_ll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/pick_image_iv"
            android:layout_margin="16dp"
            android:gravity="center_horizontal">

            <Button
                android:id="@+id/snap_shot_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="30dp"
                android:background="@drawable/bg_light_blue"
                android:text="@string/snapshot"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/confirm_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_light_blue"
                android:text="@string/confirm"
                android:textAllCaps="false" />
        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_alignParentBottom="true"
            android:orientation="vertical">

            <ProgressBar
                android:id="@+id/register_progress_bar"
                style="@style/ProgressBar_Mini"
                android:layout_width="match_parent"
                android:layout_height="10dp" />

            <TextView
                android:id="@+id/register_status_tv"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="#FFFFFF"
                android:gravity="center"
                android:textColor="@color/light_green"
                android:textSize="32sp" />

        </LinearLayout>


    </RelativeLayout>
</layout>
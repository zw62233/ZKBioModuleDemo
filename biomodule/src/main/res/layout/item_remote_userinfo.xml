<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/module_user_info_ll"
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:orientation="horizontal">


    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imageView_itemImg"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_gravity="center"
        android:layout_margin="8dp"
        app:strokeColor="@null"
        android:background="@color/color_avatar_bg"
        android:src="@drawable/default_avatar"
        app:shapeAppearance="@style/round_style" />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/user_pin_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="bottom"
            android:text="@string/text_placeholder" />

        <TextView
            android:id="@+id/user_name_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="top"
            android:text="@string/text_placeholder" />

        <TextView
            android:id="@+id/person_id_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="top"
            android:text="@string/text_placeholder" />

    </LinearLayout>

    <ImageView
        android:id="@+id/face_status_iv"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:layout_gravity="center"
        android:layout_marginEnd="8dp"
        android:background="@mipmap/ic_face" />

    <ImageView
        android:id="@+id/palm_status_iv"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:layout_gravity="center"
        android:layout_marginEnd="40dp"
        android:background="@drawable/ic_palm_gray" />

    <ImageButton
        android:id="@+id/imageButton_itemDelete"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center_vertical"
        android:layout_weight="0"
        app:srcCompat="@android:drawable/ic_delete" />

</LinearLayout>

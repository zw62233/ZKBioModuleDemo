<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <LinearLayout
        android:id="@+id/user_info_ll"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/selector_white_gray"
        android:orientation="horizontal">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imageView_itemImg"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_margin="8dp"
            android:layout_weight="0"
            app:strokeColor="@null"
            android:background="@color/color_avatar_bg"
            app:shapeAppearance="@style/round_style"
            tools:srcCompat="@tools:sample/avatars" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textView_itemID"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="bottom"
                android:text="@string/text_placeholder" />

            <TextView
                android:id="@+id/textView_itemName"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_marginTop="8dp"
                android:layout_weight="1"
                android:gravity="top"
                android:text="@string/text_placeholder" />

        </LinearLayout>

        <ImageView
            android:id="@+id/face_status_iv"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:layout_marginEnd="8dp"
            android:src="@mipmap/ic_face" />

        <ImageView
            android:id="@+id/rfid_status_iv"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_card_gray" />

        <ImageView
            android:id="@+id/palm_status_iv"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_palm_gray" />

        <ImageView
            android:id="@+id/palm_vein_status_iv"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:layout_marginEnd="40dp"
            android:src="@mipmap/ic_palm_vein_gray" />

        <ImageButton
            android:id="@+id/imageButton_itemDelete"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center_vertical"
            android:layout_weight="0"
            app:srcCompat="@android:drawable/ic_delete" />

    </LinearLayout>
</layout>

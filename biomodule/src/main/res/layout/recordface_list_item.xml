<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/linearLayout"
    android:layout_width="80dp"
    android:layout_height="80dp"
    android:layout_margin="5dp"
    android:background="@android:color/transparent"
    android:orientation="horizontal">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/record_face_image"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@color/color_avatar_bg"
        android:src="@drawable/ic_app"
        app:strokeColor="@null"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:shapeAppearance="@style/round_style" />


    <TextView
        android:id="@+id/record_face_similarity"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/anim_color_2"
        android:text="@string/text_placeholder"
        android:textColor="@android:color/background_light"
        android:textSize="12sp"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/record_face_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/anim_color_2"
        android:gravity="center"
        android:text="@string/text_placeholder"
        android:textColor="@android:color/holo_blue_bright"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
